
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Information about a user (Admin, Cambista, or Cliente)",
      "type": "object",
      "properties": {
        "nome": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "cambista", "cliente"] },
        "balance": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "approved"] },
        "cpf": { "type": "string" },
        "pixKey": { "type": "string" },
        "phone": { "type": "string" },
        "commissionRate": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["nome", "email", "role", "balance", "status"]
    },
    "Bingo": {
      "title": "Bingo Game",
      "description": "A bingo draw event",
      "type": "object",
      "properties": {
        "nome": { "type": "string" },
        "preco": { "type": "number" },
        "totalCartelas": { "type": "number" },
        "vendidas": { "type": "number" },
        "vendidasCambista": { "type": "number" },
        "dataSorteio": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["aberto", "sorteio", "encerrado"] },
        "bolasSorteadas": { "type": "array", "items": { "type": "number" } },
        "regras": { "type": "string" },
        "whatsapp": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["nome", "preco", "status", "dataSorteio"]
    },
    "Bolao": {
      "title": "Bolão Esportivo",
      "description": "A soccer pool with multiple matches",
      "type": "object",
      "properties": {
        "nome": { "type": "string" },
        "valor": { "type": "number" },
        "status": { "type": "string", "enum": ["aberto", "encerrado"] },
        "partidas": { 
          "type": "array", 
          "items": { 
            "type": "object",
            "properties": {
              "time1": { "type": "string" },
              "time2": { "type": "string" },
              "data": { "type": "string" },
              "placar1": { "type": "number" },
              "placar2": { "type": "number" },
              "status": { "type": "string" }
            }
          }
        },
        "regras": { "type": "string" },
        "whatsapp": { "type": "string" },
        "vendidas": { "type": "number" },
        "vendidasCambista": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["nome", "valor", "status"]
    },
    "Ticket": {
      "title": "Bingo/Bolao Ticket",
      "description": "A ticket sold for an event",
      "type": "object",
      "properties": {
        "eventId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userCpf": { "type": "string" },
        "cambistaId": { "type": "string" },
        "codigoIdentificacao": { "type": "string" },
        "tipo": { "type": "string", "enum": ["bingo", "bolao"] },
        "status": { "type": "string", "enum": ["pendente", "ganhou", "perdeu", "pago"] },
        "valorPremio": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["eventId", "codigoIdentificacao", "status"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": { "schema": "UserProfile", "description": "User profiles" },
    "/bingos/{bingoId}": { "schema": "Bingo", "description": "Bingo games" },
    "/boloes/{bolaoId}": { "schema": "Bolao", "description": "Bolão games" },
    "/tickets/{ticketId}": { "schema": "Ticket", "description": "Sold tickets" },
    "/transactions/{transactionId}": { "schema": "Transaction", "description": "Financial records" }
  }
}
